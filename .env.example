# Supabase client credentials. These are public/publishable keys — access is
# protected by Row Level Security. Do NOT commit real values here.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key. Required by `scripts/seed-database.cjs` and the
# `verify-slip` edge function. Must NEVER be exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Auth OAuth providers (optional). Used by `supabase/config.toml`.
# Create credentials in the Google Cloud Console / Apple Developer portal, then
# set them in your Supabase project Auth settings and as local env vars.
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
SUPABASE_AUTH_EXTERNAL_APPLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_APPLE_SECRET=

# Plant API keys (optional). Used by the species wiki and plant identifier.
# PlantNet: https://my-api.plantnet.org (identification)
NEXT_PUBLIC_PLANTNET_API_KEY=
# Perenual: https://perenual.com (care guides and species details)
NEXT_PUBLIC_PERENUAL_API_KEY=

# Sentry error tracking (optional). Set NEXT_PUBLIC_SENTRY_DSN to enable in production.
# SENTRY_AUTH_TOKEN, SENTRY_ORG and SENTRY_PROJECT are only needed to upload
# source maps during the build; they are NOT exposed to the browser.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_APP_VERSION=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=


# Bank-slip verification providers (set as Supabase Edge Function secrets).
# SlipOK: https://slipok.com — used by `verify-slip` edge function.
SLIPOK_API_KEY=
SLIPOK_BRANCH_ID=
# EasySlip: https://developer.easyslip.com (alternative provider).
EASYSLIP_API_KEY=

# Upstash Redis (used by edge functions only — never expose the token to the browser).
# Set these as Supabase Edge Function secrets with `supabase secrets set`.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Email notifications (optional). Used by the send-notification-email edge function.
# Sign up at https://resend.com to get an API key.
# Until you verify a domain, use Resend's test sender `onboarding@resend.dev`
# (emails will only reach your own Resend-account address).
EMAIL_PROVIDER_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# Cron secret: protects cron-triggered edge functions from public invocation.
# Set as a Supabase Edge Function secret and also configure the cron job to send it.
CRON_SECRET=

# Edge function CORS allow-list (comma-separated). Defaults to production Vercel URLs.
ALLOWED_ORIGINS=

# Application URL used by edge functions when generating links (e.g. emails).
APP_URL=https://roots-rho-two.vercel.app

# Contact form email backend (optional). Used by the send-contact-email Edge Function.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_TO_EMAIL=
