# Supabase client credentials. These are public/publishable keys — access is
# protected by Row Level Security. Do NOT commit real values here.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Sentry error tracking (optional). Set VITE_SENTRY_DSN to enable in production.
# SENTRY_AUTH_TOKEN, SENTRY_ORG and SENTRY_PROJECT are only needed to upload
# source maps during the build; they are NOT exposed to the browser.
VITE_SENTRY_DSN=
VITE_APP_VERSION=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Analytics provider (optional). Set one of the following.
# Plausible: domain only, e.g. root.market
VITE_PLAUSIBLE_DOMAIN=
# Google Analytics 4: measurement ID, e.g. G-XXXXXXXXXX
VITE_GA_ID=
# PostHog: project API key and host
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Omise card payments (optional). Public key for the browser; secret key lives
# in the Supabase Edge Function secrets.
VITE_OMISE_PUBLIC_KEY=

# EasySlip bank-slip verification (optional). Set in Supabase Edge Function secrets.
# Sign up at https://developer.easyslip.com to get an API key.
EASYSLIP_API_KEY=

# Upstash Redis (used by edge functions only — never expose the token to the browser).
# Set these as Supabase Edge Function secrets with `supabase secrets set`.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Email notifications (optional). Used by the send-notification-email edge function.
# Sign up at https://resend.com to get an API key.
# Until you verify a domain, use Resend's test sender `onboarding@resend.dev`
# (emails will only reach your own Resend-account address).
EMAIL_PROVIDER_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# Cron secret: protects cron-triggered edge functions from public invocation.
# Set as a Supabase Edge Function secret and also configure the cron job to send it.
CRON_SECRET=

# Edge function CORS allow-list (comma-separated). Defaults to production Vercel URLs.
ALLOWED_ORIGINS=

# Contact form email backend (optional). Used by the send-contact-email Edge Function.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_TO_EMAIL=
